# Copy to .env.local for local dev; set the same vars in Vercel project settings
# for production. Both are optional — the site builds and runs without them.

# Public base URL of the deployed site (used for metadata, OG, sitemap, robots).
# e.g. https://your-domain.com — falls back to the placeholder in data/site.ts.
NEXT_PUBLIC_SITE_URL=

# Web3Forms access key for the contact form. This key is PUBLIC by design (it is
# submitted from the browser), so it is safe to expose. Get a free key at
# https://web3forms.com (enter your email, verify it). Without this, the contact
# form falls back to opening a pre-filled mailto: link instead of sending.
NEXT_PUBLIC_WEB3FORMS_KEY=
